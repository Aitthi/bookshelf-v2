{
  "name": "bookshelf-v2",
  "version": "1.2.2",
  "description": "A lightweight ORM for PostgreSQL, MySQL, and SQLite3",
  "scripts": {
    "format": "biome format --write src test",
    "lint": "biome lint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "jsdoc": "./scripts/jsdoc.sh",
    "postpublish": "./scripts/postpublish.sh",
    "build:esm": "swc src -d dist/esm --strip-leading-paths -C module.type=es6",
    "build:cjs": "swc src -d dist/cjs --strip-leading-paths -C module.type=commonjs",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "rm -rf dist && pnpm build:esm && pnpm build:cjs && pnpm build:types && node scripts/fix-dist-pkg.mjs",
    "fix:sqlite3": "node scripts/rebuild-sqlite3.mjs",
    "check": "biome check src test"
  },
  "homepage": "https://bookshelfjs.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aitthi/re-bookshelf.git"
  },
  "keywords": [
    "orm",
    "mysql",
    "mysql2",
    "postgresql",
    "sqlite",
    "datamapper",
    "active record"
  ],
  "dependencies": {
    "bluebird": "^3.7.2",
    "create-error": "~0.3.1",
    "inflection": "^3.0.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "bookshelf-jsdoc-theme": "^1.0.1",
    "jsdoc": "^4.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.9.7",
    "pg": "^8.11.5",
    "sqlite3": "^5.1.7",
    "typescript": "^6.0.3",
    "uuid": "^9.0.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "knex": ">=3.1.0"
  },
  "author": {
    "name": "Tim Griesser",
    "url": "https://github.com/tgriesser"
  },
  "contributors": [
    {
      "name": "Edward Greve",
      "url": "https://github.com/anyong"
    },
    {
      "name": "Rhys van der Waerden",
      "url": "https://github.com/rhys-vdw"
    },
    {
      "name": "Ricardo Graça",
      "url": "https://github.com/ricardograca"
    }
  ],
  "license": "MIT",
  "readmeFilename": "README.md",
  "engines": {
    "node": ">=16"
  }
}
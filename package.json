{
  "name": "bookshelfv2",
  "version": "2.0.0",
  "type": "module",
  "description": "A lightweight ORM for PostgreSQL, MySQL, and SQLite3",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./plugins/*": {
      "types": "./dist/types/plugins/*.d.ts",
      "import": "./dist/esm/plugins/*.js",
      "require": "./dist/cjs/plugins/*.js"
    }
  },
  "scripts": {
    "format": "biome format --write src test",
    "lint": "biome lint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:esm": "swc src -d dist/esm --strip-leading-paths -C module.type=es6",
    "build:cjs": "swc src -d dist/cjs --strip-leading-paths -C module.type=commonjs",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "node scripts/gen-version.mjs && rm -rf dist && pnpm build:esm && pnpm build:cjs && pnpm build:types && node scripts/fix-dist-pkg.mjs",
    "smoke": "pnpm build && node test/smoke/esm.mjs && node test/smoke/cjs.cjs",
    "fix:sqlite3": "node scripts/rebuild-sqlite3.mjs",
    "check": "biome check src test"
  },
  "homepage": "https://github.com/Aitthi/bookshelf-v2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aitthi/bookshelf-v2.git"
  },
  "keywords": [
    "orm",
    "mysql",
    "mysql2",
    "postgresql",
    "sqlite",
    "datamapper",
    "active record"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "knex": "^3.3.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "sqlite3": "^6.0.1",
    "typescript": "^6.0.3",
    "uuid": "^14.0.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "knex": ">=3.1.0"
  },
  "author": {
    "name": "Assets Art"
  },
  "license": "MIT",
  "readmeFilename": "README.md",
  "engines": {
    "node": ">=16"
  },
  "dependencies": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "@swc/core",
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
